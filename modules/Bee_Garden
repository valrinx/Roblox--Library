-- ============================================================
--   MODULE: Bee Garden  v0.5 (Dex-aware runtime scan)
-- ============================================================

return function(Window, scriptInfo)
    local Players = game:GetService("Players")

    local player = Players.LocalPlayer
    local character = player.Character or player.CharacterAdded:Wait()
    local rootPart = character:WaitForChild("HumanoidRootPart")
    local world = workspace

    local function refreshCharacter()
        character = player.Character or player.CharacterAdded:Wait()
        rootPart = character:WaitForChild("HumanoidRootPart")
    end

    player.CharacterAdded:Connect(function()
        task.wait(0.2)
        refreshCharacter()
    end)

    local function cleanText(value)
        return tostring(value or ""):gsub("%W", ""):lower()
    end

    local function hasAny(text, keywords)
        local lowered = string.lower(tostring(text or ""))
        for _, k in ipairs(keywords) do
            if string.find(lowered, k, 1, true) then
                return true
            end
        end
        return false
    end

    local function getPartFromInstance(inst)
        if not inst then
            return nil
        end
        if inst:IsA("BasePart") then
            return inst
        end
        if inst:IsA("Attachment") and inst.Parent and inst.Parent:IsA("BasePart") then
            return inst.Parent
        end
        if inst:IsA("Model") then
            if inst.PrimaryPart then
                return inst.PrimaryPart
            end
            local anyPart = inst:FindFirstChildWhichIsA("BasePart", true)
            if anyPart then
                return anyPart
            end
        end
        if inst.Parent then
            return getPartFromInstance(inst.Parent)
        end
        return nil
    end

    local function teleportToPart(part)
        if not part then
            return false
        end
        if not rootPart or not rootPart.Parent then
            refreshCharacter()
        end
        rootPart.CFrame = part.CFrame * CFrame.new(0, 3.5, 0)
        return true
    end

    local function triggerPrompt(prompt)
        if not prompt or not prompt:IsA("ProximityPrompt") then
            return false
        end
        local holdTime = math.max(tonumber(prompt.HoldDuration) or 0, 0.1) + 0.08

        -- Method 1: executor helper with hold args
        local ok = pcall(function()
            fireproximityprompt(prompt, holdTime, true)
        end)
        if ok then return true end

        -- Method 2: basic helper
        ok = pcall(function()
            fireproximityprompt(prompt)
        end)
        if ok then return true end

        -- Method 3: native hold begin/end
        ok = pcall(function()
            prompt:InputHoldBegin()
            task.wait(holdTime)
            prompt:InputHoldEnd()
        end)
        if ok then return true end

        -- Method 4: temporary zero-hold fallback
        ok = pcall(function()
            local old = prompt.HoldDuration
            prompt.HoldDuration = 0
            fireproximityprompt(prompt)
            task.wait(0.05)
            prompt.HoldDuration = old
        end)
        return ok
    end

    local function triggerClick(click)
        if not click or not click:IsA("ClickDetector") then
            return false
        end
        local ok = pcall(function()
            fireclickdetector(click)
        end)
        return ok
    end

    local function touchPart(part)
        if not part or not part:IsA("BasePart") then
            return false
        end
        local ok = pcall(function()
            firetouchinterest(rootPart, part, 0)
            task.wait(0.03)
            firetouchinterest(rootPart, part, 1)
        end)
        return ok
    end

    local MainTab = Window:CreateTab("Bee Garden", 4483362458)
    local statusLabel = MainTab:CreateLabel("Status: Ready")
    local infoLabel = MainTab:CreateLabel("Dex Scan: pending")

    local myPlotRoot = nil
    local teleportPoints = {}
    local teleportOptions = {}
    local teleportDropdown

    local autoHatchEnabled = false
    local autoFarmPlotEnabled = false
    local autoCollectEnabled = false
    local autoClaimHoneyEnabled = false

    local function getScriptablePlots()
        local core = world:FindFirstChild("Core")
        local scriptable = core and core:FindFirstChild("Scriptable")
        return scriptable and scriptable:FindFirstChild("Plots")
    end

    local function getMyPlotKey()
        local plots = getScriptablePlots()
        if not plots then
            return nil
        end
        for _, plot in ipairs(plots:GetChildren()) do
            local ownerName = tostring(plot:GetAttribute("OwnerName") or "")
            if ownerName ~= "" and cleanText(ownerName) == cleanText(player.Name) then
                return plot.Name
            end
        end
        return nil
    end

    local function getMyScriptablePlot()
        local plots = getScriptablePlots()
        if not plots then
            return nil
        end
        local key = getMyPlotKey()
        if key and plots:FindFirstChild(key) then
            return plots:FindFirstChild(key)
        end
        for _, plot in ipairs(plots:GetChildren()) do
            local pot = plot:FindFirstChild("HoneyPot")
            if pot then
                local ownerName = tostring(pot:GetAttribute("OwnerName") or "")
                if ownerName ~= "" and cleanText(ownerName) == cleanText(player.Name) then
                    return plot
                end
            end
        end
        return nil
    end

    local function isMyEggPrompt(prompt)
        if not prompt or not prompt:IsA("ProximityPrompt") or not prompt.Enabled then
            return false
        end

        local promptType = string.lower(tostring(prompt:GetAttribute("PromptType") or ""))
        local plotOwner = cleanText(prompt:GetAttribute("PlotOwner"))
        local action = string.lower(prompt.ActionText or "")
        local objectName = string.lower(prompt.ObjectText or "")
        local promptName = string.lower(prompt.Name or "")

        -- Ignore timer/skip prompt while waiting; user confirmed this is not hatch-ready.
        if promptName == "prompt2" and promptType ~= "egg_ready" then
            return false
        end

        if plotOwner ~= "" and plotOwner ~= cleanText(player.Name) then
            return false
        end

        if promptType == "egg_ready" or promptType == "egg_hatching" then
            return true
        end

        return hasAny(action .. " " .. objectName .. " " .. promptName, {"hatch", "egg"})
    end

    local function detectMyPlot()
        local myName = cleanText(player.Name)
        local myDisplay = cleanText(player.DisplayName)
        local best

        for _, obj in ipairs(world:GetChildren()) do
            local objClean = cleanText(obj.Name)
            if objClean == myName or objClean == myDisplay then
                best = obj
                break
            end
        end

        if best then
            return best
        end

        for _, obj in ipairs(world:GetDescendants()) do
            if obj:IsA("TextLabel") then
                local txt = cleanText(obj.Text)
                if txt ~= "" and (string.find(txt, myName, 1, true) or string.find(txt, myDisplay, 1, true)) then
                    local parentModel = obj:FindFirstAncestorOfClass("Model")
                    local parentFolder = obj:FindFirstAncestorOfClass("Folder")
                    if parentModel then
                        return parentModel
                    elseif parentFolder then
                        return parentFolder
                    end
                end
            end
        end
        return nil
    end

    local function refreshTeleportPoints()
        teleportPoints = {}
        teleportOptions = {}

        local seedNames = {
            "Workspace",
            "Terrain",
            "Effects",
            "Events",
            "FollowerBees",
            "Placables",
            "LuckyBlockCommon",
            "LuckyBlockRare",
            "LuckyBlockEpic",
            "Model",
        }
        for _, n in ipairs(seedNames) do
            local obj = (n == "Workspace") and world or world:FindFirstChild(n)
            if obj then
                teleportPoints[n] = obj
            end
        end

        for _, obj in ipairs(world:GetChildren()) do
            if obj:IsA("Model") or obj:IsA("Folder") then
                if hasAny(obj.Name, {"plot", "lucky", "bee", "event"}) then
                    teleportPoints[obj.Name] = obj
                end
            end
        end

        myPlotRoot = detectMyPlot()
        if myPlotRoot then
            teleportPoints["MyPlot"] = myPlotRoot
        end

        local scriptablePlot = getMyScriptablePlot()
        if scriptablePlot then
            teleportPoints["MyScriptablePlot"] = scriptablePlot
            local honey = scriptablePlot:FindFirstChild("HoneyPot")
            if honey then
                teleportPoints["MyHoneyPot"] = honey
            end
            local eggs = scriptablePlot:FindFirstChild("Eggs")
            if eggs then
                teleportPoints["MyEggs"] = eggs
            end
        end

        for i = 1, 8 do
            local p = world:FindFirstChild("PlotModel" .. i)
            if p then
                teleportPoints[p.Name] = p
            end
        end

        for name, _ in pairs(teleportPoints) do
            table.insert(teleportOptions, name)
        end
        table.sort(teleportOptions)

        local msg = string.format(
            "Dex Scan: %d points | MyPlot: %s | %s %s",
            #teleportOptions,
            myPlotRoot and myPlotRoot.Name or "not found",
            scriptInfo.name or "Bee Garden",
            scriptInfo.version or "v0.5"
        )
        infoLabel:Set(msg)

        if teleportDropdown then
            pcall(function()
                teleportDropdown:Refresh(teleportOptions, true)
            end)
        end
    end

    refreshTeleportPoints()

    MainTab:CreateButton({
        Name = "Refresh Teleport Points (Runtime)",
        Callback = function()
            refreshTeleportPoints()
            statusLabel:Set("Status: Teleport points refreshed")
        end,
    })

    teleportDropdown = MainTab:CreateDropdown({
        Name = "Teleport To",
        Options = teleportOptions,
        CurrentValue = teleportOptions[1],
        MultipleOptions = false,
        Callback = function(option)
            local selected = type(option) == "table" and option[1] or option
            local target = selected and teleportPoints[selected]
            local targetPart = getPartFromInstance(target)
            if target == world then
                rootPart.CFrame = CFrame.new(0, 25, 0)
                statusLabel:Set("Status: Teleported to Workspace center")
                return
            end
            if targetPart and teleportToPart(targetPart) then
                statusLabel:Set("Status: Teleported to " .. tostring(selected))
            else
                statusLabel:Set("Status: Teleport failed (target not ready)")
            end
        end,
    })

    MainTab:CreateToggle({
        Name = "Auto Hatch When Ready",
        CurrentValue = false,
        Flag = "beeAutoHatch",
        Callback = function(value)
            autoHatchEnabled = value
            if value then
                statusLabel:Set("Status: Auto Hatch ON")
                task.spawn(function()
                    while autoHatchEnabled do
                        local count = 0
                        local readySeen = 0
                        local plot = getMyScriptablePlot()
                        local source = (plot and plot:FindFirstChild("Eggs")) or world
                        for _, obj in ipairs(source:GetDescendants()) do
                            if not autoHatchEnabled then
                                break
                            end
                            if obj:IsA("ProximityPrompt") then
                                if isMyEggPrompt(obj) then
                                    readySeen += 1
                                    local part = getPartFromInstance(obj)
                                    if part then
                                        teleportToPart(part)
                                        if triggerPrompt(obj) then
                                            count += 1
                                        end
                                        task.wait(0.2)
                                    end
                                end
                            end
                        end
                        statusLabel:Set("Status: Auto Hatch ON (ready: " .. tostring(readySeen) .. " | triggered: " .. tostring(count) .. ")")
                        task.wait(0.5)
                    end
                    statusLabel:Set("Status: Auto Hatch OFF")
                end)
            end
        end,
    })

    MainTab:CreateToggle({
        Name = "Auto Farm My Plot",
        CurrentValue = false,
        Flag = "beeAutoFarmMyPlot",
        Callback = function(value)
            autoFarmPlotEnabled = value
            if value then
                statusLabel:Set("Status: Auto Farm Plot ON")
                task.spawn(function()
                    while autoFarmPlotEnabled do
                        if not myPlotRoot or not myPlotRoot.Parent then
                            myPlotRoot = detectMyPlot()
                        end
                        if not myPlotRoot then
                            statusLabel:Set("Status: MyPlot not found, waiting...")
                            task.wait(1)
                        else
                            local interactions = 0
                            for _, obj in ipairs(myPlotRoot:GetDescendants()) do
                                if not autoFarmPlotEnabled then
                                    break
                                end
                                if obj:IsA("ProximityPrompt") and obj.Enabled then
                                    local part = getPartFromInstance(obj)
                                    if part then
                                        teleportToPart(part)
                                        if triggerPrompt(obj) then
                                            interactions += 1
                                        end
                                        task.wait(0.08)
                                    end
                                elseif obj:IsA("ClickDetector") then
                                    local part = getPartFromInstance(obj)
                                    if part then
                                        teleportToPart(part)
                                        if triggerClick(obj) then
                                            interactions += 1
                                        end
                                        task.wait(0.08)
                                    end
                                end
                            end
                            statusLabel:Set("Status: Plot farm interactions: " .. tostring(interactions))
                            task.wait(0.45)
                        end
                    end
                    statusLabel:Set("Status: Auto Farm Plot OFF")
                end)
            end
        end,
    })

    MainTab:CreateToggle({
        Name = "Auto Collect Bees/Coins",
        CurrentValue = false,
        Flag = "beeAutoCollect",
        Callback = function(value)
            autoCollectEnabled = value
            if value then
                statusLabel:Set("Status: Auto Collect ON")
                task.spawn(function()
                    local keys = {"bee", "coin", "honey", "token", "collect", "reward"}
                    while autoCollectEnabled do
                        local collected = 0
                        local plot = getMyScriptablePlot()
                        local source = plot or world
                        for _, obj in ipairs(source:GetDescendants()) do
                            if not autoCollectEnabled then
                                break
                            end

                            local name = string.lower(obj.Name)
                            if obj:IsA("ProximityPrompt") and obj.Enabled then
                                local text = name .. " " .. string.lower(obj.ActionText or "") .. " " .. string.lower(obj.ObjectText or "")
                                if hasAny(text, keys) then
                                    local part = getPartFromInstance(obj)
                                    if part then
                                        teleportToPart(part)
                                        if triggerPrompt(obj) then
                                            collected += 1
                                        end
                                        task.wait(0.06)
                                    end
                                end
                            elseif obj:IsA("ClickDetector") then
                                if hasAny(name, keys) then
                                    local part = getPartFromInstance(obj)
                                    if part then
                                        teleportToPart(part)
                                        if triggerClick(obj) then
                                            collected += 1
                                        end
                                        task.wait(0.06)
                                    end
                                end
                            elseif obj:IsA("BasePart") then
                                if hasAny(name, keys) then
                                    teleportToPart(obj)
                                    if touchPart(obj) then
                                        collected += 1
                                    end
                                    task.wait(0.03)
                                end
                            end
                        end
                        if plot then
                            local honeyPot = plot:FindFirstChild("HoneyPot")
                            local honeyPart = getPartFromInstance(honeyPot)
                            if honeyPart then
                                teleportToPart(honeyPart)
                                for _, item in ipairs(honeyPot:GetDescendants()) do
                                    if item:IsA("ProximityPrompt") and item.Enabled and triggerPrompt(item) then
                                        collected += 1
                                    elseif item:IsA("ClickDetector") and triggerClick(item) then
                                        collected += 1
                                    end
                                end
                                if touchPart(honeyPart) then
                                    collected += 1
                                end
                            end
                        end
                        statusLabel:Set("Status: Auto Collect ON (" .. tostring(collected) .. " hits)")
                        task.wait(0.45)
                    end
                    statusLabel:Set("Status: Auto Collect OFF")
                end)
            end
        end,
    })

    MainTab:CreateToggle({
        Name = "Auto Claim HoneyPot",
        CurrentValue = false,
        Flag = "beeAutoClaimHoneyPot",
        Callback = function(value)
            autoClaimHoneyEnabled = value
            if value then
                statusLabel:Set("Status: Auto Claim HoneyPot ON")
                task.spawn(function()
                    while autoClaimHoneyEnabled do
                        local plot = getMyScriptablePlot()
                        local honeyPot = plot and plot:FindFirstChild("HoneyPot")
                        if honeyPot then
                            local coins = tonumber(honeyPot:GetAttribute("CoinsToClaim") or 0) or 0
                            local honeyPart = getPartFromInstance(honeyPot)
                            if honeyPart and coins > 0 then
                                teleportToPart(honeyPart)
                                local claimed = false
                                for _, item in ipairs(honeyPot:GetDescendants()) do
                                    if item:IsA("ProximityPrompt") and item.Enabled and triggerPrompt(item) then
                                        claimed = true
                                    elseif item:IsA("ClickDetector") and triggerClick(item) then
                                        claimed = true
                                    end
                                end
                                if touchPart(honeyPart) then
                                    claimed = true
                                end
                                if claimed then
                                    statusLabel:Set("Status: Claimed HoneyPot (" .. tostring(coins) .. ")")
                                else
                                    statusLabel:Set("Status: HoneyPot found but no interaction path")
                                end
                            else
                                statusLabel:Set("Status: HoneyPot waiting coins...")
                            end
                        else
                            statusLabel:Set("Status: HoneyPot not found")
                        end
                        task.wait(0.7)
                    end
                    statusLabel:Set("Status: Auto Claim HoneyPot OFF")
                end)
            end
        end,
    })
end
