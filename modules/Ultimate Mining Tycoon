        local function encodeSharedColorMap()
            -- Encode as an object to avoid empty-table ambiguity ({} sometimes encodes as []).
            return HttpService:JSONEncode({
                version = 1,
                kind = "OreColorSignatureMap",
                data = sharedOreNameByColorSignature,
            })
        end

        local function decodeSharedColorMap(text)
            if type(text) ~= "string" or text == "" then
                return nil, "Empty input"
            end
            local ok, decoded = pcall(function()
                return HttpService:JSONDecode(text)
            end)
            if not ok or type(decoded) ~= "table" then
                return nil, "Invalid JSON"
            end
            -- Backwards compatible: accept either raw map or wrapped object.
            if isStringMap(decoded) then
                return decoded, nil
            end
            if type(decoded.data) == "table" and isStringMap(decoded.data) then
                return decoded.data, nil
            end
            return nil, "Expected { data: { signature: name } }"
        end

