                        local function isTargetTemporarilyBlocked(target, renderPart)
                            local key = getTargetKey(target, renderPart)
                            local t = blockedTargetUntil[key]
                            if not t then return false end
                            if t <= os.clock() then
                                blockedTargetUntil[key] = nil
                                return false
                            end
                            return true
                        end

                        local function blockTargetTemporarily(target, renderPart, seconds)
                            local key = getTargetKey(target, renderPart)
                            blockedTargetUntil[key] = os.clock() + (seconds or 2.0)
                        end

                        local function tweenToOre(rootPart, orePart)
                            if not autoMineUseTween then
                                if activeTween then
                                    pcall(function() activeTween:Cancel() end)
                                    activeTween = nil
                                end
                                return
                            end
                            if not rootPart or not orePart then return end
                            local character = rootPart.Parent
                            local humanoid = character and character:FindFirstChildOfClass("Humanoid")
                            if humanoid and humanoid.SeatPart then
                                if activeTween then
                                    pcall(function() activeTween:Cancel() end)
                                    activeTween = nil
                                end
                                return
                            end
                            local toOre = orePart.Position - rootPart.Position
                            local dist = toOre.Magnitude
                            if dist < 8 then return end
                            local targetPos = orePart.Position - toOre.Unit * 5 + Vector3.new(0, 2.5, 0)
                            local duration = math.clamp(dist / math.max(autoMineTweenSpeed, 1), 0.08, 0.35)
                            if activeTween then
                                pcall(function() activeTween:Cancel() end)
                            end
                            activeTween = TweenService:Create(
                                rootPart,
                                TweenInfo.new(duration, Enum.EasingStyle.Linear, Enum.EasingDirection.Out),
                                { CFrame = CFrame.new(targetPos) }
                            )
                            activeTween:Play()
                        end

                        while autoMineEnabled do
                            if not LocalPlayer then task.wait(0.1) continue end
                            local Character = LocalPlayer.Character
                            if not Character then task.wait(0.1) continue end
                            local Tool = GetTool()
                            local isPickaxe = Tool and string.lower(Tool.Name):find("pickaxe") ~= nil
                            if Tool and Tool.Parent == LocalPlayer.InnoBackpack and isPickaxe then
                                local equipRemote = Tool:FindFirstChild("EquipRemote")
                                if equipRemote then
                                    equipRemote:FireServer(true)
                                    task.wait(0.2)
                                end
                            end
                            local root = Character and Character:FindFirstChild("HumanoidRootPart")
                            if root then
                                local humanoid = Character:FindFirstChildOfClass("Humanoid")
                                if humanoid and humanoid.SeatPart then
                                    if activeTween then
                                        pcall(function() activeTween:Cancel() end)
                                        activeTween = nil
                                    end
                                    OreLabel:Set("Auto Mine Status: paused (in vehicle)")
                                    task.wait(0.15)
                                    continue
                                end
                                local closestBlock, closestDist = nil, math.huge

                                local oreContainers = {
                                    workspace:FindFirstChild("PlacedOre"),
                                    workspace:FindFirstChild("SpawnedBlocks"),
                                }

                                if isTargetValid(lockedTarget, root) then
                                    closestBlock = lockedTarget
                                else
                                    resetTargetLock()
                                    for _, container in ipairs(oreContainers) do
                                        if container then
                                            for _,v in pairs(container:GetChildren()) do
                                                local renderPart = getOreRenderPart(v)
                                                if renderPart then
                                                    if isTargetTemporarilyBlocked(v, renderPart) then
                                                        continue
                                                    end
                                                    local oreName = getOreName(v)
                                                    if isIgnoredOre(oreName) then
                                                        continue
                                                    end
                                                    local dist = (root.Position - renderPart.Position).Magnitude
                                                    if dist <= autoMineRange and dist < closestDist then
                                                        closestBlock = v
                                                        closestDist = dist
                                                    end
                                                end
                                            end
                                        end
                                    end
                                    lockedTarget = closestBlock
                                end

                                if closestBlock then
                                    local renderPart = getOreRenderPart(closestBlock)
                                    local oreName = getOreName(closestBlock)
                                    tweenToOre(root, renderPart)
                                    local gridPos = getTargetGridPositionDeep(closestBlock, renderPart)
                                    if not gridPos then
                                        local worldPos = renderPart and renderPart.Position
                                        if not worldPos then
                                            OreLabel:Set("Auto Mine Status: target no position")
                                            task.wait(0.03)
                                            continue
                                        end
                                        gridPos = Vector3int16.new(
                                            math.floor(worldPos.X / 4),
                                            math.floor(worldPos.Y / 4),
                                            math.floor(worldPos.Z / 4)
                                        )
                                    end
                                    local args = {10, gridPos}
                                    local activateRemote = resolveActivateRemote(Tool)
                                    if activateRemote then
                                        activateRemote:FireServer(table.unpack(args))
                                        markTargetLoop(closestBlock, renderPart)
                                        if sameTargetLoops >= stuckResetLoops then
                                            OreLabel:Set("Auto Mine Status: re-targeting (stuck)")
                                            blockTargetTemporarily(closestBlock, renderPart, 2.5)
                                            resetTargetLock()
                                            task.wait(0.08)
                                            continue
                                        end
                                        OreLabel:Set("Auto Mine Status: mining " .. tostring(oreName) .. " (locked x" .. tostring(sameTargetLoops) .. ")")
                                    else
                                        OreLabel:Set("Auto Mine Status: Activate remote missing")
                                        resetTargetLock()
                                    end
                                    task.wait(autoMineDelay)
                                    continue
                                else
                                    if activeTween then
                                        pcall(function() activeTween:Cancel() end)
                                        activeTween = nil
                                    end
                                    resetTargetLock()
                                    OreLabel:Set("Auto Mine Status: no target in range")
                                end
                            end
                            task.wait(0.03)
                        end
                        if activeTween then
                            pcall(function() activeTween:Cancel() end)
                            activeTween = nil
                        end
                    end)
                else
                    autoMineEnabled = false
                    OreLabel:Set("Auto Mine Status: Idle")
                end
