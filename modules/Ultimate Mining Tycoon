                        local function markTargetLoop(target, renderPart)
                            local sig = makeOreSignature(target, renderPart) or tostring(target)
                            if sig == lastTargetSignature then
                                sameTargetLoops = sameTargetLoops + 1
                            else
                                lastTargetSignature = sig
                                sameTargetLoops = 1
                            end
