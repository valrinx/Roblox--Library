                                    v.visual.FillColor = color
                                    v.visual.OutlineColor = color
                                    v.visual.FillTransparency = 0.78
                                    v.visual.OutlineTransparency = 0.05
                                elseif v.visual:IsA("BoxHandleAdornment") then
