    --  DETECT PLAYER'S CURRENT ISLAND
    -- ────────────────────────────────────────────────────────────
    local function getCurrentIslandName()
        if not rootPart then return nil end
        local root = mapRoot()
        if not root then return nil end
        local playerPos = rootPart.Position
        local nearest, nearestDist = nil, math.huge
        for _, island in ipairs(root:GetChildren()) do
            if island:IsA("Folder") and
               (string.match(island.Name, "^Island%d+$") or island.Name == "Island11Underground") then
                -- หาจุดศูนย์กลางของเกาะจาก BasePart ใดก็ได้
                local part = island:FindFirstChildWhichIsA("BasePart", true)
                if part then
                    local d = (part.Position - playerPos).Magnitude
                    if d < nearestDist then
                        nearestDist = d
                        nearest = island.Name
                    end
                end
            end
        end
        return nearest
    end

    -- ────────────────────────────────────────────────────────────
    --  VOIDORB DODGE
    -- ────────────────────────────────────────────────────────────
    --[[
        ตรวจจับ Part/Model ที่ชื่อมี "VoidOrb" / "voidorb" / "void_orb"
        ในรัศมี voidOrbDodgeRange แล้ว TP ถอยออกจากทิศที่ Orb บิน
    ]]
    local function detectVoidOrbs()
        if not rootPart then return {} end
        local orbs = {}
        for _, obj in ipairs(workspace:GetDescendants()) do
            local lname = string.lower(obj.Name)
            if obj:IsA("BasePart") and (lname:find("voidor") or lname:find("void_orb") or lname:find("orb_void")) then
                local d = (obj.Position - rootPart.Position).Magnitude
                if d <= voidOrbDodgeRange then
                    table.insert(orbs, obj)
                end
            end
        end
        return orbs
    end

    local function dodgeVoidOrbs()
        if not (voidOrbDodgeEnabled and rootPart) then return false end
        local orbs = detectVoidOrbs()
        if #orbs == 0 then isDodging = false; return false end

        isDodging = true
        -- คำนวณทิศหนีรวม (average threat direction แล้วถอยสวนทาง)
        local threatDir = Vector3.zero
        for _, orb in ipairs(orbs) do
            local diff = rootPart.Position - orb.Position
            -- น้ำหนักมากขึ้นถ้า orb ยิ่งใกล้
            local w = math.max(0.1, voidOrbDodgeRange - diff.Magnitude)
            threatDir = threatDir + diff.Unit * w
        end

        if threatDir.Magnitude < 0.01 then
            -- ถ้า orb อยู่ตรงๆ ให้ถอยไปด้านข้าง
            threatDir = rootPart.CFrame.RightVector
        else
            threatDir = threatDir.Unit
        end

        local dodgeTarget = rootPart.Position + Vector3.new(threatDir.X, 0, threatDir.Z) * voidOrbDodgeDist
        dodgeTarget = Vector3.new(dodgeTarget.X, rootPart.Position.Y, dodgeTarget.Z)

        if activeTween then activeTween:Cancel(); activeTween = nil end
        activeTween = TweenService:Create(
            rootPart,
            TweenInfo.new(0.08, Enum.EasingStyle.Linear, Enum.EasingDirection.Out),
            { CFrame = CFrame.new(dodgeTarget) }
        )
        activeTween:Play()
        return true
    end

