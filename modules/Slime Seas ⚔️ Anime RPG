    local function teleportToCurrentIslandWaypoint()
        local island = safeGetCurrentIsland()
        if not island then return end
        local idx = island:match("^Island(%d+)$")
        local wpName = idx and ("Waypoint_island" .. idx) or nil
        if island == "Island11Underground" then
            wpName = "Waypoint_island11Underground"
        end
        if not wpName then return end

        local pf = workspace:FindFirstChild("PlayerFolder")
        local pnode = pf and pf:FindFirstChild(LocalPlayer.Name)
        if not pnode then return end
        local wp = pnode:FindFirstChild(wpName, true)
        local pos
        if wp and wp:IsA("BasePart") then
            pos = wp.Position
        elseif wp and wp:IsA("CFrameValue") then
            pos = wp.Value.Position
        elseif wp and (wp:IsA("Vector3Value")) then
            pos = wp.Value
        end
        if pos and rootPart then
            rootPart.CFrame = CFrame.new(pos + Vector3.new(0, 5, 0))
            bossStatusLabel:Set("Boss Status: Teleported to " .. wpName)
        end
    end

