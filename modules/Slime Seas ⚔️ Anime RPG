    local function getPath(inst)
        local out, ptr = {}, inst
        while ptr and ptr ~= game do
            table.insert(out, 1, ptr.Name)
            ptr = ptr.Parent
        end
        return table.concat(out, ".")
    end

    local function findByPath(path)
        local ptr = game
        for seg in string.gmatch(path, "[^%.]+") do
            ptr = ptr and ptr:FindFirstChild(seg)
        end
        return ptr
    end

