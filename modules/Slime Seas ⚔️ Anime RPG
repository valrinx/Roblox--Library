    local BOSS_HOLD_WAIT     = 4
    local BOSS_SPAWN_WAIT    = 3
    local BOSS_POLL_INTERVAL = 0.3

    local function doAutoBoss(bossEntry)
        if bossStatusLabel then bossStatusLabel:Set("Boss: Teleporting to " .. bossEntry.island) end

        local waypoint = workspace:FindFirstChild(bossEntry.waypoint, true)
        if waypoint then
            local pos = waypoint:IsA("BasePart") and waypoint.Position
                     or (waypoint.PrimaryPart and waypoint.PrimaryPart.Position)
                     or (waypoint:FindFirstChildWhichIsA("BasePart") and waypoint:FindFirstChildWhichIsA("BasePart").Position)
            if pos and rootPart then
                teleportTo(CFrame.new(pos + Vector3.new(0, 5, 0)))
                task.wait(0.5)
            end
        end

        if bossStatusLabel then bossStatusLabel:Set("Boss: Finding BossSpawnButton…") end
        local btn = findBossSpawnButton(bossEntry.waypoint)
        if not btn then
            if bossStatusLabel then bossStatusLabel:Set("Boss: BossSpawnButton not found!") end
            task.wait(2)
            return
        end

        local btnPos = btn:IsA("BasePart") and btn.Position
                    or (btn.PrimaryPart and btn.PrimaryPart.Position)
                    or (btn:FindFirstChildWhichIsA("BasePart") and btn:FindFirstChildWhichIsA("BasePart").Position)
        if not btnPos then
            if bossStatusLabel then bossStatusLabel:Set("Boss: Cannot read button position!") end
            task.wait(2)
            return
        end

        if rootPart then
            teleportTo(CFrame.new(btnPos + Vector3.new(0, 3, 0)))
        end

        local prompt  = btn:FindFirstChildWhichIsA("ProximityPrompt", true)
        local holdDur = (prompt and prompt.HoldDuration and prompt.HoldDuration > 0)
                        and prompt.HoldDuration or BOSS_HOLD_WAIT

        if bossStatusLabel then bossStatusLabel:Set("Boss: Holding button (" .. holdDur .. "s)…") end

        local elapsed = 0
        while autoBoss and elapsed < holdDur + 0.5 do
            if rootPart then
                rootPart.CFrame = CFrame.new(btnPos + Vector3.new(0, 3, 0))
                rootPart.AssemblyLinearVelocity = Vector3.zero
            end
            if prompt then
                pcall(function() fireproximityprompt(prompt) end)
            end
            task.wait(0.1)
            elapsed += 0.1
        end

        if bossStatusLabel then bossStatusLabel:Set("Boss: Waiting for spawn…") end
        local spawnWait = 0
        local boss
        while autoBoss and spawnWait < BOSS_SPAWN_WAIT + 3 do
            boss = findLiveBoss(bossEntry.bosses)
            if boss then break end
            task.wait(BOSS_POLL_INTERVAL)
            spawnWait += BOSS_POLL_INTERVAL
        end

        if not boss then
            if bossStatusLabel then bossStatusLabel:Set("Boss: No boss spawned, retrying…") end
            task.wait(1)
            return
        end

        if bossStatusLabel then bossStatusLabel:Set("Boss: Fighting " .. boss.Name) end
        if bossTargetLabel  then bossTargetLabel:Set("Boss Target: " .. boss.Name) end

        while autoBoss and mobAlive(boss) do
            if rootPart and humanoid and humanoid.Health > 0 then
                holdAbove(boss)
                strike(boss)
                collectNearbyBoxes()
            end
            task.wait(farmDelay)
        end

        if bossTargetLabel  then bossTargetLabel:Set("Boss Target: Dead / None") end
        if bossStatusLabel  then bossStatusLabel:Set("Boss: Boss killed! Looping…") end
        task.wait(1.5)
    end

    -- ────────────────────────────────────────────────────────────
    --  WAYPOINT TP
    -- ────────────────────────────────────────────────────────────
    local function tpToWaypoint(waypointName)
        if not rootPart then return false, "Character not ready" end
        local wp = workspace:FindFirstChild(waypointName, true)
        if not wp then return false, waypointName .. " not found in workspace" end

        local pos
        if wp:IsA("BasePart") then
            pos = wp.Position
        elseif wp.PrimaryPart then
            pos = wp.PrimaryPart.Position
        else
            local part = wp:FindFirstChildWhichIsA("BasePart")
            if part then pos = part.Position end
        end

        if not pos then
            local cf = wp:GetAttribute("CFrame") or wp:GetAttribute("SpawnCFrame")
            if cf then pos = cf.Position end
        end

        if not pos then return false, "Cannot find position for " .. waypointName end

        teleportTo(CFrame.new(pos + Vector3.new(0, 5, 0)))
        return true, "TP → " .. waypointName
    end

