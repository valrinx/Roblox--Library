        if not model then return false, npcName .. " not found" end

        local npcPart = model:IsA("BasePart") and model
                     or model.PrimaryPart
                     or model:FindFirstChild("HumanoidRootPart")
                     or model:FindFirstChildWhichIsA("BasePart")
        if not npcPart then return false, "No part on " .. npcName end

