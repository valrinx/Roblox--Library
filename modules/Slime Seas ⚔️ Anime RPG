                dodgeVoidOrbs()
            end
        end

        -- Hold above target เมื่อ auto farm (ถ้าไม่ได้กำลัง dodge)
        if autoFarm and not isDodging and currentTarget and mobAlive(currentTarget) and rootPart and humanoid and humanoid.Health > 0 then
            holdAbove(currentTarget)
        end
    end)

end
