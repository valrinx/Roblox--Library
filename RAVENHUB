local customHubApi = {
    -- placeholder bridge for old modules that expect a "Window-like" object
    CreateTab = function()
        return {
            CreateLabel = function() end,
            CreateParagraph = function() end,
            CreateButton = function() end,
            CreateToggle = function() end,
            CreateDropdown = function() end,
            CreateSlider = function() end,
            CreateInput = function() end,
        }
    end,
}

local function loadScriptModule(scriptInfo)
    if loadedScripts[scriptInfo.name] then
        return
    end

    loadedScripts[scriptInfo.name] = true
    scriptCleanupHandlers[scriptInfo.name] = nil
    setScriptStatus(scriptInfo.name, "loading...")

    task.spawn(function()
        local ok, result = pcall(function()
            local raw = game:HttpGet(scriptInfo.moduleUrl)
            assert(type(raw) == "string" and #raw > 10, "HttpGet empty: " .. tostring(scriptInfo.moduleUrl))

            local chunk, compileErr = loadstring(raw)
            assert(chunk, "loadstring error: " .. tostring(compileErr))

            local moduleFunc = chunk()
            assert(type(moduleFunc) == "function", "module must return function, got: " .. type(moduleFunc))

            local runtimeInfo = table.clone(scriptInfo)
            runtimeInfo.hubWindow = customHubApi
            runtimeInfo.hubRayfield = nil
            runtimeInfo.registerCleanup = function(cleanupFn)
                if type(cleanupFn) == "function" then
                    scriptCleanupHandlers[scriptInfo.name] = cleanupFn
                end
            end

            -- Compatibility call shape from old hub: moduleFunc(Window, runtimeInfo)
            moduleFunc(customHubApi, runtimeInfo)
        end)

        if ok then
            setScriptStatus(scriptInfo.name, "loaded")
        else
            loadedScripts[scriptInfo.name] = nil
            scriptCleanupHandlers[scriptInfo.name] = nil
            setScriptStatus(scriptInfo.name, "failed (legacy module UI mismatch)")
            warn("[RAVEN HUB] Failed to load '" .. scriptInfo.name .. "': " .. tostring(result))
        end
    end)
end

for _, scriptInfo in ipairs(SCRIPTS) do
    if shouldLoadScript(scriptInfo) then
        loadScriptModule(scriptInfo)
    elseif scriptInfo.detector then
        task.spawn(function()
            for _ = 1, 30 do
                task.wait(1)
                if shouldLoadScript(scriptInfo) then
                    loadScriptModule(scriptInfo)
                    return
                end
            end
        end)
    else
        setScriptStatus(scriptInfo.name, "not matched")
    end
end