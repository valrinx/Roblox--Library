    c.Parent = inst
    return c
end

local function stroke(inst, color, t, tr)
    local s = Instance.new("UIStroke")
    s.Color = color or theme.border
    s.Thickness = t or 1
    s.Transparency = tr or 0
    s.Parent = inst
    return s
end

local function tween(inst, secs, props)
    TweenService:Create(inst, TweenInfo.new(secs, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), props):Play()
end

local function keyName(code)
    return tostring(code):gsub("Enum.KeyCode.", "")
end

local function containsId(idList, value)
    if not idList then
        return false
    end
    local v = tostring(value)
    for _, id in ipairs(idList) do
        if tostring(id) == v then
            return true
        end
    end
    return false
end

