        theme[key] = value
    end

    launcher.BackgroundColor3 = theme.accent
    main.BackgroundColor3 = theme.glass
    mainStroke.Color = theme.border
    top.BackgroundColor3 = theme.panel
    topStroke.Color = theme.border
    title.TextColor3 = theme.sub
    side.BackgroundColor3 = theme.panel
    sideStroke.Color = theme.border
    content.BackgroundColor3 = theme.card
    contentStroke.Color = theme.border

    for _, card in ipairs(cardFrames) do
        card.BackgroundColor3 = theme.panel
    end
    for _, label in ipairs(cardLabels) do
        label.TextColor3 = theme.text
    end
    for _, stroke in ipairs(cardStrokes) do
        stroke.Color = theme.border
    end

    for _, navButton in ipairs(navButtons) do
        if navButton.TextColor3 ~= Color3.fromRGB(255, 255, 255) then
            navButton.TextColor3 = theme.text
        end
    end

    for _, button in ipairs(accentButtons) do
        button.BackgroundColor3 = theme.accent
    end
end

