--   Lazy Load + Module pattern
-- ============================================================

local Rayfield    = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()
local Players     = game:GetService("Players")
local VirtualUser = game:GetService("VirtualUser")

local player    = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local camera    = game.Workspace.CurrentCamera

local SCRIPTS = {
    {
        name        = "My Knife Farm",
        description = "Auto Roll | Auto Buy | Auto Sell | Anti AFK",
        gameId      = 0,
        version     = "v0.4",
        moduleUrl   = "https://raw.githubusercontent.com/valrinx/Roblox--Library/refs/heads/main/modules/My_knife_farm",
    },
}

player.Idled:Connect(function()
    VirtualUser:Button2Down(Vector2.zero, camera.CFrame)
    task.wait(1)
    VirtualUser:Button2Up(Vector2.zero, camera.CFrame)
end)

local Window = Rayfield:CreateWindow({
    Name            = "RAVEN HUB",
    LoadingTitle    = "RAVEN HUB  |  v2.0",
    LoadingSubtitle = "by valrinx",
    ConfigurationSaving = {
        Enabled    = true,
        FolderName = "RAVENHUB",
        FileName   = "HubConfig",
    },
})

local HomeTab = Window:CreateTab("Home", 4483362458)
HomeTab:CreateLabel("Welcome to RAVEN HUB")
HomeTab:CreateLabel("PlaceId: " .. tostring(game.PlaceId))

local scriptNames = {}
for _, s in ipairs(SCRIPTS) do
    table.insert(scriptNames, s.name .. "  [" .. s.version .. "]  |  " .. s.description)
end

HomeTab:CreateDropdown({
    Name            = "Scripts in this Hub",
    Options         = scriptNames,
    CurrentValue    = scriptNames[1],
    MultipleOptions = false,
    Callback        = function() end,
})

local currentPlaceId = game.PlaceId

-- decode %XX ใน URL เผื่อ executor ไม่ decode ให้อัตโนมัติ
local function decodeUrl(url)
    return (url:gsub("%%(%x%x)", function(hex)
        return string.char(tonumber(hex, 16))
    end))
end

for _, scriptInfo in ipairs(SCRIPTS) do
    if scriptInfo.gameId == 0 or scriptInfo.gameId == currentPlaceId then
        task.spawn(function()
            local ok, result = pcall(function()
                local url = decodeUrl(scriptInfo.moduleUrl)

                -- ขั้น 1: ดึงโค้ด
                local raw = game:HttpGet(url)
                assert(type(raw) == "string" and #raw > 10,
                    "HttpGet ได้ผลว่างหรือ nil — เช็ค URL: " .. url)

                -- ขั้น 2: compile
                local fn, compileErr = loadstring(raw)
                assert(fn, "loadstring error: " .. tostring(compileErr))

                -- ขั้น 3: รัน → ได้ module function
                local moduleFunc = fn()
                assert(type(moduleFunc) == "function",
                    "module ต้อง return function แต่ได้: " .. type(moduleFunc))

                -- ขั้น 4: เรียก module
                moduleFunc(Window, scriptInfo)
            end)
            if not ok then
                warn("[RAVEN HUB] Failed to load '" .. scriptInfo.name .. "': " .. tostring(result))
            end
        end)
    end
end

local HubSettingsTab = Window:CreateTab("Hub Settings", 4483362458)

HubSettingsTab:CreateButton({
    Name = "Destroy Hub",
    Callback = function() Rayfield:Destroy() end,
})