local function addTab(name)
    local page = createPage(name)
    pages[name] = page

    local button = Instance.new("TextButton")
    button.Size = UDim2.fromOffset(166, 34)
    button.Text = name
    button.Font = Enum.Font.Gotham
    button.TextSize = 13
    button.TextColor3 = theme.text
    button.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    button.BackgroundTransparency = 1
    button.BorderSizePixel = 0
    button.Parent = side
    round(button, 9)

    button.MouseEnter:Connect(function()
        if not page.Visible then
            tween(button, 0.12, {BackgroundTransparency = 0.92, BackgroundColor3 = theme.accent})
        end
    end)
    button.MouseLeave:Connect(function()
        if not page.Visible then
            tween(button, 0.12, {BackgroundTransparency = 1})
        end
    end)

    button.MouseButton1Click:Connect(function()
        for _, pageFrame in pairs(pages) do
            pageFrame.Visible = false
        end
        for _, navButton in ipairs(navButtons) do
            tween(navButton, 0.12, {BackgroundTransparency = 1})
            navButton.TextColor3 = theme.text
        end
        page.Visible = true
        tween(button, 0.12, {BackgroundTransparency = 0.88, BackgroundColor3 = theme.accent})
        button.TextColor3 = Color3.fromRGB(255, 255, 255)
    end)

    table.insert(navButtons, button)
    return page
end

