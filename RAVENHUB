-- ============================================================
--   LAZY LOAD
-- ============================================================

local currentPlaceId = game.PlaceId
local currentGameId  = game.GameId

local function containsId(idList, value)
    if not idList then return false end
    local valueStr = tostring(value)
    for _, id in ipairs(idList) do
        if tostring(id) == valueStr then
            return true
        end
    end
    return false
end

local function shouldLoadScript(scriptInfo)
    if scriptInfo.detector then
        local ok, matched = pcall(scriptInfo.detector)
        if ok and matched then
            return true
        end
    end

    if scriptInfo.universal == true then
        return true
    end

    if scriptInfo.placeIds and containsId(scriptInfo.placeIds, currentPlaceId) then
        return true
    end

    if scriptInfo.gameIds and containsId(scriptInfo.gameIds, currentGameId) then
        return true
    end

    -- backward compatibility for old schema
    if scriptInfo.gameId == 0 then
        return true
    end
    if scriptInfo.gameId == currentPlaceId or scriptInfo.gameId == currentGameId then
        return true
    end

    return false
end

-- map fingerprint fallback for cases where PlaceId/GameId differs across sub-places
for _, scriptInfo in ipairs(SCRIPTS) do
    if scriptInfo.name == "Ultimate Mining Tycoon" then
        scriptInfo.detector = function()
            return workspace:FindFirstChild("PlacedOre") ~= nil
                and workspace:FindFirstChild("SpawnedBlocks") ~= nil
        end
        break
    end
end

local loadedScripts = {}
local scriptCleanupHandlers = {}

local function loadScriptModule(scriptInfo)
    if loadedScripts[scriptInfo.name] then return end
    loadedScripts[scriptInfo.name] = true
    scriptCleanupHandlers[scriptInfo.name] = nil

    task.spawn(function()
        local ok, result = pcall(function()
            local raw = game:HttpGet(scriptInfo.moduleUrl)
            assert(type(raw) == "string" and #raw > 10,
                "HttpGet empty — URL: " .. scriptInfo.moduleUrl)

            local fn, compileErr = loadstring(raw)
            assert(fn, "loadstring error: " .. tostring(compileErr))

            local moduleFunc = fn()
            assert(type(moduleFunc) == "function",
                "module must return function, got: " .. type(moduleFunc))

            local runtimeInfo = table.clone(scriptInfo)
            runtimeInfo.hubRayfield = Rayfield
            runtimeInfo.hubWindow = Window
            runtimeInfo.registerCleanup = function(cleanupFn)
                if type(cleanupFn) == "function" then
                    scriptCleanupHandlers[scriptInfo.name] = cleanupFn
                end
            end

            moduleFunc(Window, runtimeInfo)
        end)
        if not ok then
            loadedScripts[scriptInfo.name] = nil
            scriptCleanupHandlers[scriptInfo.name] = nil
            warn("[RAVEN HUB] Failed to load '" .. scriptInfo.name .. "': " .. tostring(result))
        end
    end)
end

for _, scriptInfo in ipairs(SCRIPTS) do
    if shouldLoadScript(scriptInfo) then
        loadScriptModule(scriptInfo)
    elseif scriptInfo.detector then
        task.spawn(function()
            for _ = 1, 30 do
                task.wait(1)
                if shouldLoadScript(scriptInfo) then
                    loadScriptModule(scriptInfo)
                    return
                end
            end
        end)
    end
end

